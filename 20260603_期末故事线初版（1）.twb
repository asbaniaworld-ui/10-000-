              <calculation class='tableau' formula='IF [rank] &lt;= 100 THEN &quot;Top 100&quot;&#13;&#10;ELSEIF [rank] &gt;= 9000 AND [rank] &lt;= 10000 THEN &quot;Edge (9000-10000)&quot;&#13;&#10;ELSE &quot;Middle(101-9000)&quot;&#13;&#10;END' />
