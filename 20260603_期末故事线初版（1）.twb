                    <story-points>
                      <story-point caption='纵观整个 2024 年音乐流派的市场占有率，Pop（流行乐）以 4,469 的绝对优势高居第一，Rock（摇滚乐）以 2,417 稳居第二。然而，这两个流派的命运曲线在历史的长河中发生过一次历史性的“王权交替”。' captured-sheet='仪表板 3' id='1'>
                        <currentDeltas>
                          <worksheet name='五种不同风格歌手的作品分布'>
                            <selection-collection />
                          </worksheet>
                        </currentDeltas>
                        <capturedDeltas />
                      </story-point>
                    </story-points>
