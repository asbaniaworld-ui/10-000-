      <aliases enabled='yes' />
      <column caption='Group' datatype='string' name='[Calculation_0757567049478145]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [rank] &lt;= 100 THEN &quot;Top 100&quot;&#13;&#10;ELSEIF [rank] &gt;= 9000 AND [rank] &lt;= 10000 THEN &quot;Edge (9000-10000)&quot;&#13;&#10;ELSE &quot;Middle(101-9000)&quot;&#13;&#10;END' />
      </column>
      <column caption='Explict占比' datatype='real' name='[Calculation_1636635930185729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([explicit]) / COUNT([track_id])' />
      </column>
